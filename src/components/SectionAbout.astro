---
import { site } from "../config";
---

<section
  class="flex flex-col items-center gap-12 px-6 pb-28 md:px-12 lg:flex-row lg:gap-20 lg:pb-36 lg:pl-20 lg:pr-20"
>
  <div class="reveal relative h-[420px] w-full shrink-0 overflow-hidden lg:h-[500px] lg:w-[400px]">
    <img
      src="/images/portrait.png"
      alt={`Le fondateur de ${site.name} à son poste de travail, à ${site.city}.`}
      class="absolute inset-0 h-full w-full object-cover"
      loading="lazy"
    />
  </div>

  <div class="flex flex-col gap-8">
    <p class="section-label reveal">05 ——</p>
    <h2
      class="reveal font-display text-[clamp(2rem,4.5vw,3rem)] font-normal leading-[1.1] text-black"
      data-delay="80"
    >
      «&nbsp;Qui est derrière&nbsp;»
    </h2>
    <p class="reveal text-lg leading-[1.7] text-black md:text-xl" data-delay="160">
      {site.name}, studio web basé à {site.city}. Je travaille avec un
      nombre limité d'artisans pour faire les choses bien. Pas un call-center,
      pas un contrat de 5 ans : la personne qui construit votre site est celle
      qui décroche quand vous appelez.
    </p>
  </div>
</section>
