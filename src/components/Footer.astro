---
import { site } from "../config";
---

<footer
  class="flex flex-col gap-6 bg-ink px-6 py-14 text-sm text-paper/70 md:flex-row md:items-center md:justify-between md:px-12 lg:px-20"
>
  <p>{site.name} · {site.city}</p>
  <div class="flex flex-wrap gap-6">
    <a href={site.phoneHref} class="nav-link transition-colors hover:text-paper">
      {site.phoneDisplay}
    </a>
    <a
      href={`mailto:${site.email}`}
      class="nav-link transition-colors hover:text-paper"
    >
      {site.email}
    </a>
    <a href="/#audit" class="nav-link transition-colors hover:text-paper">Audit gratuit</a>
    <a href="/mentions-legales" class="nav-link transition-colors hover:text-paper">
      Mentions légales
    </a>
  </div>
</footer>
