---
import { site } from "../config";
---

<footer
  class="flex flex-col gap-6 border-t border-ink/10 px-6 py-10 text-sm text-ink/50 md:flex-row md:items-center md:justify-between md:px-12 lg:px-20"
>
  <p>{site.founder} · Studio web · {site.city}</p>
  <div class="flex flex-wrap gap-6">
    <a href={site.phoneHref} class="nav-link transition-colors hover:text-ink">
      {site.phoneDisplay}
    </a>
    <a
      href={`mailto:${site.email}`}
      class="nav-link transition-colors hover:text-ink"
    >
      {site.email}
    </a>
    <a href="#audit" class="nav-link transition-colors hover:text-ink">Audit gratuit</a>
    <a href="/mentions-legales" class="nav-link transition-colors hover:text-ink">
      Mentions légales
    </a>
  </div>
</footer>
