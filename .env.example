# URL du webhook n8n qui reçoit les demandes d'audit et envoie l'email.
# Copier ce fichier en `.env` et renseigner la vraie valeur.
N8N_WEBHOOK_URL="https://n8n.exemple.com/webhook/audit-peintre"

# (Optionnel) Jeton partagé envoyé dans l'en-tête X-Form-Token vers n8n,
# à vérifier côté n8n pour filtrer les soumissions non légitimes.
N8N_WEBHOOK_TOKEN=""
